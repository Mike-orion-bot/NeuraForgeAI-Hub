# ===================================
# VARIABLES DE ENTORNO - TEMPLATE
# ===================================
# Copia este archivo a .env y rellena los valores reales
# NO SUBIR .env A GITHUB - SOLO AGREGAR VALORES EN RENDER DASHBOARD

# -------- FastAPI & Seguridad --------
# IMPORTANTE: Generar una clave segura con:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=cambiar-esto-por-una-clave-segura-en-produccion
ACCESS_TOKEN_EXPIRE_MINUTES=1440
PORT=10000

# -------- Base de datos --------
# LOCAL (desarrollo): sqlite:///./database.db
# PRODUCCION Render: postgresql://user:password@host:port/dbname
DATABASE_URL=sqlite:///./database.db

# -------- Stripe (Payment Processing) --------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_1_...

# -------- PayPal (Payment Processing) --------
PAYPAL_CLIENT_ID=tu_client_id_aqui
PAYPAL_CLIENT_SECRET=tu_client_secret_aqui

# -------- MercadoPago (Payment Processing) --------
MP_ACCESS_TOKEN=tu_access_token_aqui

# -------- Integraciones Opcionales --------
TELEGRAM_TOKEN=tu_token_aqui
ADMIN_PASSWORD=tu_password_aqui
SUPABASE_URL=tu_url_aqui
SUPABASE_KEY=tu_key_aqui
